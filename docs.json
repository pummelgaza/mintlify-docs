        {
          "anchor": "Website",
          "icon": "globe",
          "href": "https://pummelgaza.com"
        },
        {
          "anchor": "Blog",
          "href": "https://pummelgaza.com/blog",
          "icon": "newspaper"
        },
        {
          "anchor": "X (Twitter)",
          "icon": "x-twitter",
          "href": "https://x.com/pummelgaza"
        }
      ]
    },
    "groups": []
  },
  "logo": {
    "light": "/logo/GuardixBlack.png",
    "dark": "/logo/GuardixWhite.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://guardix.xyz/discord",
